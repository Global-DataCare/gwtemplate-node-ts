# Bob local GW profile for two-host autodiscovery smoke.
# Copy to `.env.bob` for local use:
#   cp env.bob.example .env.bob

NODE_ENV=demo
LOCAL_SERVICE_ROLE=HOST,ICA,CA

SECURITY_MODE=demo
NETWORK_MODE=test
FHIR_LEGACY=true
JSON_LEGACY=true
DEMO_ALLOW_INSECURE_BEARER=true
DEV_SEED=true

MAINSECTOR=health
SUBSECTORSALLOWED=research,care,index

HOST_LEGAL_NAME="Gateway Bob Operator"
HOST_JURISDICTION=ES
HOST_ID_TYPE=TAX
HOST_ID_VALUE=BOB0011223345
HOST_ADMIN_EMAIL=admin@bob-host.example.org
HOST_ADMIN_UID=bob-host-admin-001
HOST_ADMIN_ROLE="ISCO-08:1111"
HOST_TERMS_URL=https://example.org/bob/terms

HOST_EXTERNAL_DOMAIN=
HOST_EXTERNAL_PORT=
ICA_EXTERNAL_DOMAIN=test-eur-ica.unid.online
CA_EXTERNAL_DOMAIN=test-eur-root.unid.online
HOST_INTERNAL_IP=0.0.0.0
HOST_INTERNAL_PORT=3001

PAYMENT_PROVIDER=stripe
INVOICE_PROVIDER=stripe
INVOICE_FLOW=pre
STRIPE_TAX_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8081/payment/success
STRIPE_CANCEL_URL=http://localhost:8081/payment/cancel

KEK_SECRET=your-super-secret-256-bits-base64-key

LEGACY_SIGN_ALG=ES384
SMART_TOKEN_LEGACY=true
LEGACY_X509_DER_BASE64=
LEGACY_X509_CHAIN_BASE64=

LEDGER_PROVIDER_DEFAULT=mem
LEDGER_PROVIDER_MAP=test=mem,test-network=mem,network=mem
LEDGER_FABRIC_MSP_ID=Org1MSP
LEDGER_FABRIC_ITEM_TYPE=credential

LOCAL_CA_ARTIFACTS_DIR=
LOCAL_ICA_ARTIFACTS_DIR=

LOG_PROVIDER=console
QUEUE_PROVIDER=mem
DB_PROVIDER=mem
STORAGE_PROVIDER=mem

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2:latest

FIRESTORE_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
FIREBASE_API_KEY=

AUTH_TOKEN_VERIFIER=demo
EIDAS_ISSUER=
EIDAS_CLIENT_ID=
EIDAS_JWKS_URI=

GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

DEPLOY_REGION=europe-southwest1
DEPLOY_SERVICE_NAME=gwtemplate-bob
ARTIFACT_REGISTRY_NAME=gwtemplate-repo
