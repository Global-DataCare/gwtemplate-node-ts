{
  "name": "gwtemplate-node-ts",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "main": "src/server.ts",
  "type": "commonjs",
  "engines": {
    "node": "^22.0.0"
  },
  "scripts": {
    "start": "node build/server.js",
    "clean": "rm -rf build",
    "build": "npm run clean && tsc",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node --transpile-only' src/server.ts",
    "prettier": "prettier --write \"src/**/*.ts\"",
    "prettier:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint 'src/**/*.{ts,js}' --fix",
    "lint:check": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watchAll",
    "test:unit": "jest --coverage src/__tests__/unit",
    "test:integration": "jest --coverage src/__tests__/integration",
    "seed:dev": "ts-node scripts/seed-dev-cas.ts",
    "update-deps": "node update-deps.js",
    "docker:build": "./docker_build.sh",
    "docker:run": "./docker_run.sh"
  },
  "dependencies": {
    "@hyperledger/fabric-gateway": "^1.9.0",
    "@hyperledger/fabric-protos": "^0.3.7",
    "@noble/ciphers": "^2.0.0",
    "@noble/post-quantum": "^0.5.1",
    "@stablelib/base64": "^2.0.1",
    "@stablelib/utf8": "^2.0.1",
    "@types/argon2": "^0.14.1",
    "@types/base-x": "^3.0.0",
    "argon2": "^0.44.0",
    "base-x": "^5.0.1",
    "canonicalize": "^2.1.0",
    "env-var": "^7.5.0",
    "express": "^4.18.2",
    "firebase-admin": "^13.5.0",
    "google-auth-library": "^9.0.0",
    "jose": "^4.15.9",
    "js-base64": "^3.7.8",
    "mongodb": "^5.6.0",
    "multiformats": "^13.4.1",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@peculiar/webcrypto": "^1.5.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/pako": "^2.0.4",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^10.0.0",
    "babel-jest": "^30.1.2",
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.1.10",
    "pkijs": "^3.2.5",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6"
  }
}
