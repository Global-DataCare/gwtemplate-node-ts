{
  "name": "gwtemplate-node-ts",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "main": "src/server.ts",
  "scripts": {
    "start": "node build/index.js",
    "clean": "rm -rf build",
    "build": "npm run clean && npm run build:copy-yaml && npm run build:types",
    "build:copy-yaml": "mkdir -p build/docs/openapi && find src/docs/openapi -name '*.yaml' -exec cp {} build/docs/openapi/ \\; || echo 'No YAML files to copy'",
    "build:types": "tsc",
    "dev": "concurrently \"npm run dev:types\" \"npm run dev:watch-yaml\" \"nodemon --exec tsc -- -p tsconfig.json\"",
    "dev:types": "tsc --watch",
    "dev:watch-yaml": "nodemon --watch src/docs/openapi/*.yaml --exec 'npm run build:copy-yaml'",
    "prettier": "prettier --write \"src/**/*.ts\"",
    "prettier:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint 'src/**/*.{ts,js}' --fix",
    "lint:check": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch",
    "test": "npm run test:unit && npm run test:integration",
    "test:cov": "jest --coverage",
    "test:unit": "jest --config=jest.config.unit.ts --detectOpenHandles --silent",
    "test:unit:watch": "npm run test:unit -- --watchAll",
    "test:integration": "jest --config=jest.config.integration.ts --detectOpenHandles --silent",
    "test:integration:writer": "env-cmd NODE_ENV=development WRITE_INTEGRATION=true jest --config=jest.config.integration.ts --detectOpenHandles",
    "test:integration:watch": "npm run test:integration -- --watchAll",
    "update-deps": "node update-deps.js",
    "docker:build": "./docker_build.sh",
    "docker:run": "./docker_run.sh"
  },
  "dependencies": {
    "@noble/ciphers": "^2.0.0",
    "@noble/hashes": "^2.0.0",
    "@noble/post-quantum": "^0.5.1",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "firebase-admin": "^11.10.1",
    "google-auth-library": "^9.0.0",
    "jose": "^4.14.4",
    "mongodb": "^5.6.0",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/pako": "^2.0.4",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
