# Firestore demo profile (local runtime)
# Usage:
#   cp env.firestore-demo.example .env.firestore-demo
#   # fill secrets/ids, then run:
#   npm run api:local-firestore-demo

NODE_ENV=demo
SECURITY_MODE=demo
NETWORK_MODE=test
DEMO_ALLOW_INSECURE_BEARER=true
DEV_SEED=true

LOG_PROVIDER=console
QUEUE_PROVIDER=mem
DB_PROVIDER=firestore
STORAGE_PROVIDER=gcs

FIRESTORE_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# Optional for auth-related demo flows
FIREBASE_API_KEY=
DEMO_ORG1_ADMIN_EMAIL=
DEMO_ORG1_ADMIN_EMAIL_PASSWORD=
