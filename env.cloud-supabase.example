# Cloud Supabase profile (full runtime)
# Usage:
#   cp env.cloud-supabase.example .env.cloud-supabase
#   npm run api:cloud-supabase

NODE_ENV=demo
LOCAL_SERVICE_ROLE=HOST,ICA,CA
SECURITY_MODE=demo
NETWORK_MODE=test
FHIR_LEGACY=true
JSON_LEGACY=true
DEMO_ALLOW_INSECURE_BEARER=true
DEV_SEED=true

MAINSECTOR=health
SUBSECTORSALLOWED=research,care,index

HOST_LEGAL_NAME="Gateway Host Services"
HOST_JURISDICTION=EU
HOST_ID_TYPE=TAX
HOST_ID_VALUE=A0011223344
HOST_ADMIN_EMAIL=admin@host.com
HOST_ADMIN_UID=host-admin-001
HOST_ADMIN_ROLE="ISCO-08:1111"
HOST_TERMS_URL=http://github.com/.../terms/en

HOST_EXTERNAL_DOMAIN=
HOST_EXTERNAL_PORT=
ICA_EXTERNAL_DOMAIN=test-eur-ica.unid.online
CA_EXTERNAL_DOMAIN=test-eur-root.unid.online
HOST_INTERNAL_IP=0.0.0.0
HOST_INTERNAL_PORT=3000

PAYMENT_PROVIDER=stripe
INVOICE_PROVIDER=stripe
INVOICE_FLOW=pre
STRIPE_TAX_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8081/payment/success
STRIPE_CANCEL_URL=http://localhost:8081/payment/cancel

KEK_SECRET=your-super-secret-256-bits-base64-key

LEGACY_SIGN_ALG=ES384
SMART_TOKEN_LEGACY=true
LEGACY_X509_DER_BASE64=
LEGACY_X509_CHAIN_BASE64=

LEDGER_PROVIDER_DEFAULT=mem
LEDGER_PROVIDER_MAP=test=mem,test-network=mem,network=mem
LEDGER_FABRIC_MSP_ID=Org1MSP
LEDGER_FABRIC_ITEM_TYPE=credential

LOCAL_CA_ARTIFACTS_DIR=
LOCAL_ICA_ARTIFACTS_DIR=

LOG_PROVIDER=console
QUEUE_PROVIDER=mem
DB_PROVIDER=postgres
STORAGE_PROVIDER=supabase

POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-db-password
POSTGRES_SSL=true
POSTGRES_SCHEMA=public
POSTGRES_MAX_POOL_SIZE=10

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=gw-files
SUPABASE_STORAGE_PUBLIC=true
