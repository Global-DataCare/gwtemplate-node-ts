# .env.example
# Copy this file to .env and fill in the values for your local development environment.

# --- Server Configuration ---
PORT=3000
API_HOSTNAME=localhost

# A comma-separated list of the business sectors this gateway is configured to serve.
# This is a required field. The 'test' sector is always implicitly available.
# Example: health-care,emergency,health-insurance
SECTORS_ALLOWED=health-care,emergency

# -------------------------------------
# DATABASE & QUEUE PROVIDERS
# -------------------------------------
# Defines the primary database and storage provider for vaults.
# Options: "mem", "mongodb", "firestore"
DB_PROVIDER=mem

# Defines the provider for the job queue.
# Options: "mem", "redis", "rabbitmq"
QUEUE_PROVIDER=mem


# --- MongoDB Configuration ---
# Required if DB_PROVIDER=mongodb
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB_NAME=antifraudgw


# --- Firebase/Firestore Configuration ---
# Required if DB_PROVIDER=firestore
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Google OAuth Configuration ---
# GOOGLE_CLIENT_ID=

