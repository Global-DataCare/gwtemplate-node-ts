# .env

# ==============================================================================
# Environment Settings
# ==============================================================================
# 'demo' activates the DemoKmsService which does not require JWE/JWS.
# 'development' is also valid but requires full crypto.
NODE_ENV=demo
LOCAL_SERVICE_ROLE=HOST,ICA,CA

# ==============================================================================
# Security & Network Modes
# ==============================================================================
# SECURITY_MODE controls transport/auth policy (strict|compat|demo).
SECURITY_MODE=compat
# NETWORK_MODE controls ledger/host registry environment (test|test-network|network).
# If omitted, it falls back to NODE_ENV mapping.
NETWORK_MODE=test
# Legacy compatibility flags under SECURITY_MODE=compat
FHIR_LEGACY=true
JSON_LEGACY=true
DIDCOMM_PLAIN=disabled
DEMO_ALLOW_INSECURE_BEARER=false


# ==============================================================================
# Deterministic Key Generation (For Development)
# ==============================================================================
# CRITICAL for dev/test: ensures the server generates the same keys on every startup.
# This allows tests and curl commands to work consistently.
DEV_SEED=true

# ==============================================================================
# Gateway & Host Configuration
# ==============================================================================
# Main business vertical enabled by this host (`animal` or `health`).
MAINSECTOR=health
# Possible subsectors: research,care,index,tech
# Effective sectors: <MAINSECTOR>-research,<MAINSECTOR>-care,<MAINSECTOR>-index,<MAINSECTOR>-tech
SUBSECTORSALLOWED=research,care,index

# ==============================================================================
# Host Organization Bootstrap Details (REQUIRED)
# ==============================================================================
# These values are used to bootstrap the host tenant if it doesn't exist.
# Legacy ORG_HOST_* is still accepted by the server.
HOST_LEGAL_NAME="Gateway Host Services"
HOST_JURISDICTION=ES
HOST_ID_TYPE=TAX
HOST_ID_VALUE=A0011223344
HOST_ADMIN_EMAIL=admin@host.com
HOST_ADMIN_UID=host-admin-001
HOST_ADMIN_ROLE="ISCO-08|1111" # Example: Chief Executive Officer
HOST_TERMS_URL=http://github.com/.../terms/en

# ==============================================================================
# URLs & Host Configuration
# ==============================================================================

# --- Public DOMAIN for the hosting service (Highest Priority) ---
HOST_EXTERNAL_DOMAIN=
HOST_EXTERNAL_PORT=
# Optional: explicit public domains for local authority well-known endpoints
# (used in demo/authority publication and ICA status validation flows).
# ICA_EXTERNAL_DOMAIN=test-eur-ica.unid.online
# CA_EXTERNAL_DOMAIN=test-eur-root.unid.online

# --- Internal Binding Configuration (Lowest Priority & Local Dev) ---
HOST_INTERNAL_IP=localhost
HOST_INTERNAL_PORT=3000

PAYMENT_PROVIDER=stripe
INVOICE_PROVIDER=stripe
INVOICE_FLOW=pre
STRIPE_TAX_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# ==============================================================================
# Security & KMS
# ==============================================================================
# CRITICAL: A Base64-encoded, 32-byte (256-bit) secret for the Key Encryption Key.
# The value below is for development only. DO NOT use in production.
KEK_SECRET=your-super-secret-256-bits-base64-key

# ==============================================================================
# Legacy Signing (ECDSA) for Gaia-X / X.509 exposure
# ==============================================================================
LEGACY_SIGN_ALG=ES384
SMART_TOKEN_LEGACY=true
LEGACY_X509_DER_BASE64=
LEGACY_X509_CHAIN_BASE64=

# ==============================================================================
# Gaia-X Clearing House (VP verification)
# ==============================================================================
# Modes: stub (default, local), remote (future).
CLEARING_HOUSE_MODE=stub
CLEARING_HOUSE_URL=

# ==============================================================================
# ICA activation / DID document publication
# ==============================================================================
# Optional. When configured, `Organization/_activate` will call ICA
# `entity/did/document/_create` after local tenant activation.
# If the value already includes `/entity/did/document/_create`, it is used as-is.
ICA_MODE=
ICA_URL_INTERNAL=
ICA_URL_EXTERNAL=
ICA_TLS_CA_PEM=

# ==============================================================================
# Ledger routing (credential status/history)
# ==============================================================================
LEDGER_PROVIDER_DEFAULT=mem
LEDGER_PROVIDER_MAP=test=mem,test-network=mem,network=mem
LEDGER_FABRIC_MSP_ID=Org1MSP
LEDGER_FABRIC_ITEM_TYPE=credential

# Default ledger channel when no jurisdiction/sector is provided
LEDGER_IDENTITY_CHANNEL_DEFAULT=eu-identity


# Optional overrides for local authority artifacts
LOCAL_CA_ARTIFACTS_DIR=
LOCAL_ICA_ARTIFACTS_DIR=

# ==============================================================================
# PKI Generation (scripts/generate-pki-chain.ts)
# ==============================================================================
ROOT_CA_DOMAIN=root-ca.example.com
ROOT_CA_REGION=EU
ROOT_CA_JURISDICTION=ES
ROOT_CA_CITY=Madrid
ROOT_CA_STREET=Calle Example 1
ROOT_CA_POSTAL_CODE=28001
ROOT_CA_LEGAL_ID_TYPE=VAT
ROOT_CA_LEGAL_ID_NUMBER=ESX0000000X
ROOT_CA_LEGAL_NAME=Root CA Org
ROOT_CA_SEED=

ICA_DOMAIN=ica.example.com
ICA_REGION=EU
ICA_JURISDICTION=ES
ICA_CITY=Madrid
ICA_STREET=Calle Example 1
ICA_POSTAL_CODE=28001
ICA_LEGAL_ID_TYPE=VAT
ICA_LEGAL_ID_NUMBER=ESX0000000X
ICA_LEGAL_NAME=ICA Org
ICA_SEED=

# Host certificate details (used for PKI, not host tenant)
HOST_REGION=EU
HOST_JURISDICTION=ES
HOST_CITY=Madrid
HOST_STREET=Calle Example 1
HOST_POSTAL_CODE=28001
HOST_LEGAL_ID_TYPE=VAT
HOST_LEGAL_ID_NUMBER=ESX0000000X
HOST_LEGAL_NAME=Host Org
HOST_DOMAIN=host.example.com
HOST_CN=host.example.com
HOST_SEED=

# ==============================================================================
# Fabric CA Admin Credentials (optional)
# ==============================================================================
ROOT_CA_ADMIN_USER=
ROOT_CA_ADMIN_PASS=
ICA_ADMIN_USER=
ICA_ADMIN_PASS=

# ==============================================================================
# Fabric Gateway Connection (optional, demo/test)
# ==============================================================================
HLF_CERTIFICATE_Org1MSP=
HLF_PRIVATE_KEY_Org1MSP=
HLF_CONNECTION_PROFILE_Org1MSP=
HLF_CONNECTION_PEM_Org1MSP=
HLF_CONNECTION_PEER_Org1MSP=

HLF_CERTIFICATE_Org2MSP=
HLF_PRIVATE_KEY_Org2MSP=
HLF_CONNECTION_PROFILE_Org2MSP=
HLF_CONNECTION_PEM_Org2MSP=
HLF_CONNECTION_PEER_Org2MSP=

# ==============================================================================
# Backend Service Providers
# ==============================================================================

# 'console' is the default and is suitable for local dev and Google Cloud Run.
LOG_PROVIDER=console

# 'mem' uses in-memory providers suitable for local development without external dependencies.
QUEUE_PROVIDER=mem
DB_PROVIDER=mem|firestore
STORAGE_PROVIDER=gcs
# Replay protection provider:
# - none: disabled (default)
# - mem: in-memory anti-replay cache keyed by <vaultId>:<iss>:<jti>
# - redis: distributed anti-replay cache (SET NX EX)
REPLAY_PROTECTION_PROVIDER=none
REDIS_URL=redis://127.0.0.1:6379
REPLAY_REDIS_KEY_PREFIX=replay:jti

# ==============================================================================
# Local LLM (optional, for conversational anonymization/derivation)
# ==============================================================================
# Provider selector (current prototype): "ollama"
LLM_PROVIDER=ollama
# Base URL for Ollama (host mode: http://127.0.0.1:11434, docker-compose: http://ollama:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Model tag available in your Ollama installation (e.g. "gemma2:latest")
OLLAMA_MODEL=gemma2:latest

# ==============================================================================
# GCP Project & Credentials (Required for non-'mem' providers)
# ==============================================================================
# The GCP project ID where your Firestore and GCS bucket are.
FIRESTORE_PROJECT_ID=your-gcp-project-id

# The name of the GCS bucket for file storage.
GCS_BUCKET_NAME=your-globally-unique-bucket-name

# For testing user authentication.
FIREBASE_API_KEY=firebase-web-api

# ==============================================================================
# Auth / Federation (OIDC -> Firebase)
# ==============================================================================
# Which id_token verifier to use for `/auth/*` and `registry/firebase/Token/_exchange`.
# - demo: decode-only (dev/tests)
# - unset/other: verify Firebase ID tokens via Firebase Admin
AUTH_TOKEN_VERIFIER=demo

# eIDAS OIDC verification config (used by `identity/firebase/Token/_custom`).
EIDAS_ISSUER=
EIDAS_CLIENT_ID=
EIDAS_JWKS_URI=

# Path to Google Cloud credentials file for local development.
# For Docker/Cloud Run, you would typically use service account roles instead.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# ==============================================================================
# GCP Deployment Configuration (for cloud_deploy.sh)
# ==============================================================================
# The Google Cloud region to deploy the service. Madrid is "europe-southwest1".
DEPLOY_REGION=europe-southwest1

# The public name for the service on Google Cloud Run.
DEPLOY_SERVICE_NAME=gwtemplate

# The name for the repository in Google Artifact Registry where the Docker image will be stored.
ARTIFACT_REGISTRY_NAME=gwtemplate-repo

# ==============================================================================
# Build-Time Secrets
# ==============================================================================
# If your project has private npm packages, provide a token with read access.
# This is passed during 'docker build' but not stored in the final image.
# NPM_TOKEN="your-npm-token"
