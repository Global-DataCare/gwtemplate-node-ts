# .env

# ==============================================================================
# Environment Settings
# ==============================================================================
# 'demo' activates the DemoKmsService which does not require JWE/JWS.
# 'development' is also valid but requires full crypto.
NODE_ENV=demo

# ==============================================================================
# Deterministic Key Generation (For Development)
# ==============================================================================
# CRITICAL for dev/test: ensures the server generates the same keys on every startup.
# This allows tests and curl commands to work consistently.
DEV_SEED=true

# ==============================================================================
# Gateway & Host Configuration
# ==============================================================================
# Comma-separated list of business sectors this gateway is allowed to manage.
SECTORS_ALLOWED=health-care,emergency,test

# ==============================================================================
# Host Organization Bootstrap Details (REQUIRED)
# ==============================================================================
# These values are used to bootstrap the host tenant if it doesn't exist.
ORG_HOST_LEGAL_NAME="Gateway Host Services"
ORG_HOST_JURISDICTION=ES
ORG_HOST_ID_TYPE=TAX
ORG_HOST_ID_VALUE=A0011223344
ORG_HOST_ADMIN_EMAIL=admin@host.com
ORG_HOST_ADMIN_UID=host-admin-001
ORG_HOST_ADMIN_ROLE="ISCO-08:1111" # Example: Chief Executive Officer
ORG_HOST_TERMS_URL=http://github.com/.../terms/en

# ==============================================================================
# URLs & Host Configuration
# ==============================================================================

# --- Public DOMAIN for the hosting service (Highest Priority) ---
HOST_EXTERNAL_DOMAIN=
HOST_EXTERNAL_PORT=

# --- Internal Binding Configuration (Lowest Priority & Local Dev) ---
HOST_INTERNAL_NAME=localhost
HOST_INTERNAL_PORT=3000

STRIPE_WEBHOOK_SIGNING_SECRET=

# ==============================================================================
# Security & KMS
# ==============================================================================
# CRITICAL: A Base64-encoded, 32-byte (256-bit) secret for the Key Encryption Key.
# The value below is for development only. DO NOT use in production.
KEK_SECRET=your-super-secret-256-bits-base64-key

# ==============================================================================
# Backend Service Providers
# ==============================================================================

# 'console' is the default and is suitable for local dev and Google Cloud Run.
LOG_PROVIDER=console

# 'mem' uses in-memory providers suitable for local development without external dependencies.
QUEUE_PROVIDER=mem
DB_PROVIDER=mem|firestore
STORAGE_PROVIDER=gcs

# ==============================================================================
# GCP Project & Credentials (Required for non-'mem' providers)
# ==============================================================================
# The GCP project ID where your Firestore and GCS bucket are.
FIRESTORE_PROJECT_ID=your-gcp-project-id

# The name of the GCS bucket for file storage.
GCS_BUCKET_NAME=your-globally-unique-bucket-name

# For testing user authentication.
FIREBASE_API_KEY=firebase-web-api

# Path to Google Cloud credentials file for local development.
# For Docker/Cloud Run, you would typically use service account roles instead.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# ==============================================================================
# GCP Deployment Configuration (for cloud_deploy.sh)
# ==============================================================================
# The Google Cloud region to deploy the service. Madrid is "europe-southwest1".
DEPLOY_REGION=europe-southwest1

# The public name for the service on Google Cloud Run.
DEPLOY_SERVICE_NAME=gwtemplate

# The name for the repository in Google Artifact Registry where the Docker image will be stored.
ARTIFACT_REGISTRY_NAME=gwtemplate-repo

# ==============================================================================
# Build-Time Secrets
# ==============================================================================
# If your project has private npm packages, provide a token with read access.
# This is passed during 'docker build' but not stored in the final image.
# NPM_TOKEN="your-npm-token"

